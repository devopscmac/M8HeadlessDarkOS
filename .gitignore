Arkbuild/
Arkbuild32/
Arkbuild-final/
Arkbuild_ccache/
Arkbuild_package_cache/
mnt/

# Disk images
*.img
*.img.7z
*.img.7z.001
*.img.7z.002

# Build logs
build.log
build.log.*

# Toolchain (downloaded during build, not committed)
/opt/toolchains/

